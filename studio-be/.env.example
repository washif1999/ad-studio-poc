# ── Required ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
CREATOMATE_API_KEY=your_creatomate_api_key_here

# ── Optional: Turso production DB ─────────────────────
# Leave these blank for local development.
# When blank, the app uses a local SQLite file (adstudio.db) automatically.
# To use Turso: pip install libsql-client, then fill these in.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Optional: image generation ────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
# Without this, images fall back to placeholder URLs.
HF_API_KEY=

# ── Not needed ────────────────────────────────────────
# Voice is handled by Microsoft Edge TTS — free, no key required.
